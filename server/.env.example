PORT=3100
NODE_ENV=production
MONGODB_URI=mongodb://your-db-host:27017/sellforme
JWT_SECRET=your-strong-random-jwt-secret-at-least-32-chars
JWT_EXPIRES_IN=2h
ADMIN_JWT_SECRET=your-strong-random-admin-jwt-secret-at-least-32-chars
ADMIN_JWT_EXPIRES_IN=8h
UPLOAD_DIR=uploads
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
TRUST_PROXY=true
